# AnnotSV - Annotation and Ranking of Structural Variations
# https://github.com/lgmgeo/AnnotSV
# Based on AnnotSV v3.5.5
#
# Build:  singularity build annotsv.sif AnnotSV.def
# Run:    singularity run annotsv.sif -help
# Exec:   singularity exec annotsv.sif AnnotSV -SVinputFile input.vcf -outputDir /data

Bootstrap: docker
From: ubuntu:22.04

%labels
    Author kchennen@unistra.fr
    Description AnnotSV - Annotation and Ranking of Structural Variations
    Version 3.5.5

%environment
    export ANNOTSV=/opt/AnnotSV
    export PATH="/opt/AnnotSV/bin:/root/.local/bin:${PATH}"
    export LC_ALL=C

%post
    export DEBIAN_FRONTEND=noninteractive
    export ANNOTSV_VERSION=v3.5.5

    # Install system dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        tcl \
        tcllib \
        make \
        git \
        bedtools \
        bcftools \
        default-jre-headless \
        python3 \
        python3-pip \
        python3-venv \
        curl \
        wget \
        tar \
        unzip \
        gzip \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

    # Install Poetry
    curl -sSL https://install.python-poetry.org | python3 -
    ln -s /root/.local/bin/poetry /usr/local/bin/poetry

    # Clone and install AnnotSV (includes variantconvert via pip)
    cd /opt
    git clone --depth 1 --branch ${ANNOTSV_VERSION} https://github.com/lgmgeo/AnnotSV.git
    cd AnnotSV
    make PREFIX=. install

    # Install Exomiser REST prioritiser JAR only (USEANNODIR=1 skips phenotype data)
    # Phenotype data (~2GB) is NOT bundled — bind-mount annotations at runtime
    make PREFIX=. USEANNODIR=1 install-exomiser-1

%runscript
    exec AnnotSV "$@"

%help
    AnnotSV v3.5.5 - Annotation and Ranking of Structural Variations

    Annotations must be bind-mounted at runtime (includes Exomiser phenotype data).

    Usage:
      singularity run \
        -B /path/to/annotations:/opt/AnnotSV/share/AnnotSV \
        -B /path/to/data:/data \
        annotsv.sif \
        -SVinputFile /data/input.vcf \
        -outputDir /data/output

    For full documentation: https://github.com/lgmgeo/AnnotSV
